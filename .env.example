# Copy this file to `.env` (cp .env.example .env) and fill in the key.
# `.env` is auto-loaded from the repo root at startup and is git-ignored.
# A real exported / inline env var always overrides what's set here.
#
# Optional. Only needed to (re)extract NEW or CHANGED image invoices on a cache
# miss. The repo ships the 5 provided invoices pre-extracted in cache/, so the
# pipeline runs fully offline without this key.
ANTHROPIC_API_KEY=

# Optional overrides
# PKB_VISION_MODEL=claude-opus-4-8
# PKB_EMBED_MODEL=BAAI/bge-small-en-v1.5
